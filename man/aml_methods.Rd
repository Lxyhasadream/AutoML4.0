\name{aml_methods}
\alias{aml_methods}
\title{List available AutoML4R feature-selection methods}
\usage{
aml_methods()
}
\description{
Returns the method names accepted by the \code{methods} argument of \code{auto_ml_analysis()}.
}
\value{
A character vector of available feature-selection method names.
}
\examples{
aml_methods()
}
